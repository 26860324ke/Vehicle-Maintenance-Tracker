{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account profile document storing display name and registration metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "passwordHash": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "email", "name", "createdAt"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Vehicle tracking details owned by a specific user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "vin": { "type": "string" },
        "currentMileage": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "make", "model", "year", "currentMileage", "createdAt"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "description": "Service log details for a vehicle.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "date": { "type": "string" },
        "serviceType": { "type": "string" },
        "cost": { "type": "number" },
        "mileageAtService": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "vehicleId", "date", "serviceType", "cost", "mileageAtService", "createdAt"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "Maintenance reminder for a vehicle, either mileage-based or date-based.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "serviceType": { "type": "string" },
        "type": { "type": "string", "enum": ["mileage", "date"] },
        "targetMileage": { "type": "number" },
        "targetDate": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "vehicleId", "serviceType", "type", "isCompleted", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Registered user accounts mapping to auth UID."
    },
    "vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Primary vehicle registers indexed by vehicle UID."
    },
    "vehicles/{vehicleId}/logs/{logId}": {
      "schema": "MaintenanceLog",
      "description": "Chronological history of repairs, oils, and inspections for the vehicle."
    },
    "vehicles/{vehicleId}/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Schedule of upcoming maintenance trackers for the vehicle."
    }
  }
}
